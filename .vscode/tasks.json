{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build SCSS",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "npx sass assets/scss/style.scss:assets/css/style.css --style=expanded --source-map"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Watch SCSS",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "npx sass --watch assets/scss/style.scss:assets/css/style.css --style=expanded --source-map"
      ],
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
